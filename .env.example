# Orchestra API — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

PORT=5000
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/orchestra

# Generate with: openssl rand -base64 32  (or any random 32-char string)
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Card360 / Interswitch
CARD360_ENABLED=false
CARD360_BASE_URL=https://qa.interswitchng.com
CARD360_TOKEN=
CARD360_CLIENT_ID=
CARD360_CLIENT_SECRET=

# AI (Groq)
GROQ_API_KEY=

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
