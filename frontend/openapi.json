{
  "openapi": "3.0.0",
  "info": {
    "title": "Orchestra API",
    "description": "Programmable ATM Card Orchestration Platform API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://orchestra-y8vf.onrender.com",
      "description": "Production server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "role": { "type": "string", "enum": ["individual", "business"] },
          "businessName": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "Card": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "pan": { "type": "string" },
          "expiryDate": { "type": "string" },
          "issuerNr": { "type": "string" },
          "cardStatus": { "type": "string" },
          "cardType": { "type": "string", "enum": ["debit", "prepaid", "virtual"] },
          "label": { "type": "string" },
          "isDefault": { "type": "boolean" },
          "spendLimit": { "type": "number" }
        }
      },
      "VirtualCard": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "userId": { "type": "string" },
          "parentCardId": { "type": "string" },
          "label": { "type": "string" },
          "merchant": { "type": "string" },
          "spendLimit": { "type": "number" },
          "amountSpent": { "type": "number" },
          "autoRenew": { "type": "boolean" },
          "paused": { "type": "boolean" },
          "pan": { "type": "string" },
          "expiryDate": { "type": "string" }
        }
      },
      "BusinessCard": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "businessUserId": { "type": "string" },
          "assignedTo": { "type": "string" },
          "purpose": { "type": "string" },
          "budget": { "type": "number" },
          "amountSpent": { "type": "number" },
          "merchantCategories": { "type": "array", "items": { "type": "string" } },
          "expiresAt": { "type": "string", "format": "date-time" },
          "status": { "type": "string", "enum": ["active", "suspended", "exhausted"] },
          "approvalThreshold": { "type": "number" },
          "pan": { "type": "string" }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "pan": { "type": "string" },
          "cardId": { "type": "string" },
          "userId": { "type": "string" },
          "amount": { "type": "number" },
          "currency": { "type": "string" },
          "merchant": { "type": "string" },
          "category": { "type": "string" },
          "transactionDate": { "type": "string", "format": "date-time" },
          "isAnomaly": { "type": "boolean" },
          "anomalyReason": { "type": "string" }
        }
      },
      "RoutingRule": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "mode": { "type": "string", "enum": ["primary", "balanced", "auto-split"] },
          "primaryCardId": { "type": "string" },
          "cardOrder": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register a new user",
        "tags": ["Auth"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "minLength": 8 },
                  "role": { "type": "string", "enum": ["individual", "business"] },
                  "businessName": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User registered successfully" },
          "400": { "description": "Validation error" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login user",
        "tags": ["Auth"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Successful login" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "summary": "Get current authenticated user",
        "tags": ["Auth"],
        "responses": {
          "200": { "description": "User profile returned" }
        }
      }
    },
    "/api/cards": {
      "get": {
        "summary": "Get all cards for the user",
        "tags": ["Cards"],
        "responses": {
          "200": { "description": "List of cards" }
        }
      },
      "post": {
        "summary": "Add a new physical card",
        "tags": ["Cards"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Card" }
            }
          }
        },
        "responses": {
          "201": { "description": "Card created" }
        }
      }
    },
    "/api/cards/{id}": {
      "get": {
        "summary": "Get a specific card",
        "tags": ["Cards"],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Card object" } }
      },
      "patch": {
        "summary": "Update a card (Block/Unblock)",
        "tags": ["Cards"],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "action": { "type": "string", "enum": ["block", "unblock"] }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Card updated" } }
      },
      "delete": {
        "summary": "Delete a card",
        "tags": ["Cards"],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Card removed" } }
      }
    },
    "/api/cards/{id}/balance": {
      "get": {
        "summary": "Fetch latest live balance from Card360",
        "tags": ["Cards"],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Live balance fetched" } }
      }
    },
    "/api/virtual-cards": {
      "get": {
        "summary": "List all virtual cards",
        "tags": ["Virtual Cards"],
        "responses": { "200": { "description": "List of virtual cards" } }
      },
      "post": {
        "summary": "Create a virtual card",
        "tags": ["Virtual Cards"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["label", "parentCardId", "spendLimit"],
                "properties": {
                  "label": { "type": "string" },
                  "parentCardId": { "type": "string" },
                  "spendLimit": { "type": "number", "description": "In Naira" },
                  "merchant": { "type": "string" },
                  "autoRenew": { "type": "boolean", "default": true }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Virtual card created" } }
      }
    },
    "/api/virtual-cards/{id}": {
      "patch": {
        "summary": "Pause, resume, or delete a virtual card",
        "tags": ["Virtual Cards"],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["action"],
                "properties": {
                  "action": { "type": "string", "enum": ["pause", "resume", "delete"] }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Virtual card modified" } }
      }
    },
    "/api/business": {
      "get": {
        "summary": "Get all business cards and pending actions",
        "tags": ["Business Cards"],
        "responses": { "200": { "description": "List of business cards" } }
      },
      "post": {
        "summary": "Create an employee expense card",
        "tags": ["Business Cards"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["assignedTo", "budget"],
                "properties": {
                  "assignedTo": { "type": "string" },
                  "purpose": { "type": "string" },
                  "budget": { "type": "number", "description": "In Naira" },
                  "merchantCategories": { "type": "array", "items": { "type": "string" } },
                  "expiresAt": { "type": "string", "format": "date-time" },
                  "approvalThreshold": { "type": "number", "description": "In Naira" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Business card created" } }
      }
    },
    "/api/business/{id}": {
      "patch": {
        "summary": "Suspend or reactivate a business card",
        "tags": ["Business Cards"],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": { "type": "string", "enum": ["active", "suspended"] }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Business card status updated" } }
      }
    },
    "/api/business/approve": {
      "post": {
        "summary": "Approve or reject an expense request",
        "tags": ["Business Cards"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["requestId", "action"],
                "properties": {
                  "requestId": { "type": "string" },
                  "action": { "type": "string", "enum": ["approve", "reject"] },
                  "note": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Request processed" } }
      }
    },
    "/api/transactions": {
      "get": {
        "summary": "Get user transactions",
        "tags": ["Transactions"],
        "parameters": [
          { "in": "query", "name": "cardId", "schema": { "type": "string" } },
          { "in": "query", "name": "category", "schema": { "type": "string" } },
          { "in": "query", "name": "page", "schema": { "type": "integer", "default": 1 } },
          { "in": "query", "name": "limit", "schema": { "type": "integer", "default": 50 } }
        ],
        "responses": { "200": { "description": "Paginated transaction list" } }
      },
      "post": {
        "summary": "Create a transaction using routing engine",
        "tags": ["Transactions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["amount"],
                "properties": {
                  "amount": { "type": "number", "description": "Amount in kobo" },
                  "merchant": { "type": "string" },
                  "category": { "type": "string" },
                  "cardId": { "type": "string", "description": "Optional forced card override" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Transaction created successfully" } }
      }
    },
    "/api/routing": {
      "get": {
        "summary": "Get user routing rule",
        "tags": ["Routing"],
        "responses": { "200": { "description": "Routing rule object" } }
      },
      "put": {
        "summary": "Upsert user routing rule",
        "tags": ["Routing"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RoutingRule" }
            }
          }
        },
        "responses": { "200": { "description": "Routing rule updated" } }
      }
    },
    "/api/routing/simulate": {
      "post": {
        "summary": "Simulate routing + anomaly engine logic",
        "tags": ["Routing"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "amount": { "type": "number", "description": "In Naira (e.g. 5000 for N5000)" },
                  "merchant": { "type": "string" },
                  "category": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Simulation result" } }
      }
    },
    "/api/anomalies": {
      "get": {
        "summary": "Get all flagged anomalies",
        "tags": ["Anomalies"],
        "responses": { "200": { "description": "List of anomalous transactions" } }
      }
    },
    "/api/insights": {
      "get": {
        "summary": "Get cached AI financial advisor analysis",
        "tags": ["Insights"],
        "responses": { "200": { "description": "Insight object generated by OpenAI" } }
      }
    },
    "/api/insights/savings": {
      "post": {
        "summary": "What-if savings calculator",
        "tags": ["Insights"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "adjustments": {
                    "type": "object",
                    "additionalProperties": { "type": "number" },
                    "description": "Multiplier map e.g. {\"food\": 0.8, \"subscriptions\": 0.5}"
                  }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Savings projection object" } }
      }
    },
    "/api/report": {
      "get": {
        "summary": "Full formatted spending report for export",
        "tags": ["Report"],
        "parameters": [
          { "in": "query", "name": "days", "schema": { "type": "integer", "default": 30 } }
        ],
        "responses": { "200": { "description": "Formatted financial report JSON" } }
      }
    }
  }
}
